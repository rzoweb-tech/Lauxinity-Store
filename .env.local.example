# Lauxinity Store Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================
# APP CONFIG
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Lauxinity
NEXT_PUBLIC_APP_DESCRIPTION=Trusted Service, Beyond Expectations.

# ============================================
# STORAGE
# ============================================
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=products

# ============================================
# ADMIN
# ============================================
# Admin email (must be registered in Supabase Auth)
ADMIN_EMAIL=admin@lauxinity.com
